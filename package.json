{
  "name": "ai-usage",
  "version": "1.0.0",
  "description": "Track token usage across multiple AI coding CLI platforms",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-usage": "./bin/ai-usage"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "token",
    "usage",
    "tracker"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.1.0",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dayjs": "^1.11.21"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
